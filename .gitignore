# Job logs (HPC output files at any depth)
**/*.o[0-9]*

# Job scripts
**/job_*
**/*.job

# IDE / tool config
.claude/
.vscode/

# Python venv
.venv/

# IRT chunk intermediate outputs (regenerated by scripts/01_fit_irt.r)
**/irt_person_scores_[0-9]*.csv
**/irt_item_parameters_[0-9]*.csv
**/m2_[0-9]*.csv
**/q3_[0-9]*.csv
**/irt_item_fit_[0-9]*.csv

# Raw / intermediate data files (use data/data.zip instead)
data/*.csv

# Per-model item selection outputs (generated by atlas_random_parallel.r)
**/selected_items_*/

# Tinybenchmark response matrices (large intermediate data, regenerated by create_tinybenchmark_response_matrix_*.r)
**/gaussian_sampled_*.csv

# Baseline comparison intermediate theta results (regenerated from item IDs + IRT params)
experiments/baseline_compare/theta_comparison_*.csv
experiments/baseline_compare/tinybenchmark_calibration/response_matrix_*.csv

# R graphics output
**/Rplots.pdf

# Log files
**/*.log

# Root-level SGE job script
/job

# Docs build
docs/
